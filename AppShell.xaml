<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CheckYoSelfAI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CheckYoSelfAI"
    xmlns:views="clr-namespace:CheckYoSelfAI.Views"
    Title="Check Yo Self AI"
    Style="{StaticResource ShellBaseStyle}"
    FlyoutBehavior="Disabled">

    <!--
    The overall app visual hierarchy is defined here, along with navigation behavior and styling.
    https://docs.microsoft.com/dotnet/maui/fundamentals/shell/
    -->

    <Shell.Resources>
        <ResourceDictionary>
            <!-- Shell visual states and styling -->
            <Style x:Key="BaseStyle" TargetType="Element">
                <Setter Property="Shell.BackgroundColor" Value="{StaticResource Primary}" />
                <Setter Property="Shell.ForegroundColor" Value="{StaticResource White}" />
                <Setter Property="Shell.TitleColor" Value="{StaticResource White}" />
                <Setter Property="Shell.DisabledColor" Value="{StaticResource Gray400}" />
                <Setter Property="Shell.UnselectedColor" Value="{StaticResource Gray200}" />
                <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource White}" />
                <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource Primary}"/>
                <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource Gray500}"/>
                <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource OnBackground}"/>
            </Style>

            <!-- Tab bar specific styling -->
            <Style BasedOn="{StaticResource BaseStyle}" TargetType="TabBar">
                <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource White}" />
                <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource Primary}" />
            </Style>

            <!-- Individual tab styling -->
            <Style TargetType="Tab">
                <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource Primary}" />
                <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource Gray500}" />
                <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource OnBackground}" />
            </Style>

            <!-- Flyout styling (if needed in future) -->
            <Style BasedOn="{StaticResource BaseStyle}" TargetType="FlyoutItem" />
        </ResourceDictionary>
    </Shell.Resources>

    <!-- 
    Main application tabs with document processing workflow
    Includes accessibility support for screen readers and navigation aids
    -->
    <TabBar Style="{StaticResource DocumentTabBarStyle}">
        <!-- Home Tab - Document Processing Dashboard -->
        <ShellContent
            Title="Home"
            Route="home"
            Style="{StaticResource DocumentShellContentStyle}"
            ContentTemplate="{DataTemplate local:MainPage}">
            <!-- Accessibility support -->
            <SemanticProperties.Description>Home</SemanticProperties.Description>
            <SemanticProperties.Hint>Navigate to the home dashboard for document processing</SemanticProperties.Hint>
            <ShellContent.Icon>
                <FontImageSource 
                    Glyph="&#xE80F;" 
                    FontFamily="SegoeFluentIcons"
                    Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryLight}}" />
            </ShellContent.Icon>
        </ShellContent>

        <!-- Settings Tab - Configuration and Preferences -->
        <ShellContent
            Title="Settings" 
            Route="settings"
            Style="{StaticResource DocumentShellContentStyle}"
            ContentTemplate="{DataTemplate views:SettingsPage}">
            <!-- Accessibility support -->
            <SemanticProperties.Description>Settings</SemanticProperties.Description>
            <SemanticProperties.Hint>Navigate to settings and configuration options</SemanticProperties.Hint>
            <ShellContent.Icon>
                <FontImageSource 
                    Glyph="&#xE713;" 
                    FontFamily="SegoeFluentIcons"
                    Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryLight}}" />
            </ShellContent.Icon>
        </ShellContent>
    </TabBar>

</Shell>
