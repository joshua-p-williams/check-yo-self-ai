<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CheckYoSelfAI.Controls.ErrorMessageView"
             x:Name="Root"
             SemanticProperties.Description="Status message"
             SemanticProperties.Hint="Displays warnings and errors related to current form state">

    <Border Padding="10"
            IsVisible="{Binding IsVisibleMessage, Source={x:Reference Root}}"
            BackgroundColor="{Binding BackgroundColorValue, Source={x:Reference Root}}"
            Stroke="{Binding StrokeColorValue, Source={x:Reference Root}}">
        <Grid ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="8">
            <Label Grid.Column="0"
                   Text="{Binding IconGlyph, Source={x:Reference Root}}"
                   FontAttributes="Bold"
                   VerticalTextAlignment="Start"
                   TextColor="{Binding TextColorValue, Source={x:Reference Root}}" />

            <Label Grid.Column="1"
                   Text="{Binding Message, Source={x:Reference Root}}"
                   FontSize="12"
                   TextColor="{Binding TextColorValue, Source={x:Reference Root}}"
                   LineBreakMode="WordWrap" />

            <Button Grid.Column="2"
                    Text="Dismiss"
                    FontSize="11"
                    Padding="8,4"
                    IsVisible="{Binding IsDismissible, Source={x:Reference Root}}"
                    Command="{Binding DismissCommand, Source={x:Reference Root}}" />
        </Grid>
    </Border>
</ContentView>
