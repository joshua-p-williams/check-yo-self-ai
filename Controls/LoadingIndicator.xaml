<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CheckYoSelfAI.Controls.LoadingIndicator"
             x:Name="Root">

    <Grid x:Name="RootContainer"
          IsVisible="{Binding IsActive, Source={x:Reference Root}}"
          Opacity="0"
          InputTransparent="False">
        <Grid BackgroundColor="#000000"
              Opacity="0.25"
              IsVisible="{Binding ShowOverlay, Source={x:Reference Root}}" />

        <Border x:Name="LoadingCard"
                Padding="14"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                IsVisible="{Binding IsActive, Source={x:Reference Root}}">
            <VerticalStackLayout Spacing="8"
                                 HorizontalOptions="Center">
                <ActivityIndicator IsRunning="{Binding IsActive, Source={x:Reference Root}}"
                                   IsVisible="{Binding IsActive, Source={x:Reference Root}}"
                                   Color="{Binding IndicatorColor, Source={x:Reference Root}}"
                                   WidthRequest="{Binding IndicatorSize, Source={x:Reference Root}}"
                                   HeightRequest="{Binding IndicatorSize, Source={x:Reference Root}}"
                                   SemanticProperties.Description="Loading" />
                <Label Text="{Binding Message, Source={x:Reference Root}}"
                       FontSize="12"
                       HorizontalTextAlignment="Center"
                       IsVisible="{Binding HasMessage, Source={x:Reference Root}}"
                       SemanticProperties.Description="Loading message" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>
